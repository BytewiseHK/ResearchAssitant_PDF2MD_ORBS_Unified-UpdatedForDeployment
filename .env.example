# Backend runtime
HOST=0.0.0.0
PORT=8000

# Cookies + sessions (seconds)
SESSION_TTL_SECONDS=7200

# OpenRouter (optional override; users provide key per-session)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Use `openrouter/free` for a free-model router, or set a specific free model id like:
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_MODEL=openrouter/free

# CORS (comma-separated). Required if you host frontend separately (e.g. Vercel).
# Example:
# CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Frontend path overrides (optional)
# FRONTEND_PATH=./frontend
# STATIC_PATH=./frontend/static
# NOTE_PATH=./frontend/notebook
# RESEARCH_PATH=./frontend/research


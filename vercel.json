{
  "builds": [
    { "src": "frontend/static/**", "use": "@vercel/static" },
    { "src": "frontend/**/index.html", "use": "@vercel/static" },
    { "src": "frontend/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/session/(.*)$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/session/$1" },
    { "src": "^/chatbot-answer$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/chatbot-answer" },
    { "src": "^/clear-chat-history$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/clear-chat-history" },
    { "src": "^/files-upload$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/files-upload" },
    { "src": "^/analyze$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/analyze" },
    { "src": "^/upload$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/upload" },
    { "src": "^/generate$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/generate" },
    { "src": "^/research/candidates$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/research/candidates" },
    { "src": "^/write/candidates$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/write/candidates" },
    { "src": "^/discuss$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/discuss" },
    { "src": "^/database/(.*)$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/database/$1" },
    { "src": "^/database$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/database" },
    { "src": "^/download/(.*)$", "dest": "https://researchassitant-pdf2md-orbs-unified.onrender.com/download/$1" },

    { "src": "^/app/static/(.*)$", "dest": "/frontend/static/$1" },
    { "src": "^/app/research/?$", "dest": "/frontend/research/index.html" },
    { "src": "^/app/research/.*$", "dest": "/frontend/research/index.html" },
    { "src": "^/app/notebook/?$", "dest": "/frontend/notebook/index.html" },
    { "src": "^/app/notebook/.*$", "dest": "/frontend/notebook/index.html" },
    { "src": "^/app/?$", "dest": "/frontend/index.html" },
    { "src": "^/app/.*$", "dest": "/frontend/index.html" },
    { "src": "^/$", "dest": "/frontend/index.html" }
  ]
}


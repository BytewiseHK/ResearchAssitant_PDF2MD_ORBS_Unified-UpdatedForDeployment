{
  "builds": [
    { "src": "frontend/static/**", "use": "@vercel/static" },
    { "src": "frontend/**/index.html", "use": "@vercel/static" },
    { "src": "frontend/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/session/(.*)$", "dest": "https://RENDER_BACKEND_HOST/session/$1" },
    { "src": "^/chatbot-answer$", "dest": "https://RENDER_BACKEND_HOST/chatbot-answer" },
    { "src": "^/clear-chat-history$", "dest": "https://RENDER_BACKEND_HOST/clear-chat-history" },
    { "src": "^/files-upload$", "dest": "https://RENDER_BACKEND_HOST/files-upload" },
    { "src": "^/analyze$", "dest": "https://RENDER_BACKEND_HOST/analyze" },
    { "src": "^/upload$", "dest": "https://RENDER_BACKEND_HOST/upload" },
    { "src": "^/generate$", "dest": "https://RENDER_BACKEND_HOST/generate" },
    { "src": "^/discuss$", "dest": "https://RENDER_BACKEND_HOST/discuss" },
    { "src": "^/database/(.*)$", "dest": "https://RENDER_BACKEND_HOST/database/$1" },
    { "src": "^/database$", "dest": "https://RENDER_BACKEND_HOST/database" },
    { "src": "^/download/(.*)$", "dest": "https://RENDER_BACKEND_HOST/download/$1" },

    { "src": "^/app/static/(.*)$", "dest": "/frontend/static/$1" },
    { "src": "^/app/research/?$", "dest": "/frontend/research/index.html" },
    { "src": "^/app/research/.*$", "dest": "/frontend/research/index.html" },
    { "src": "^/app/notebook/?$", "dest": "/frontend/notebook/index.html" },
    { "src": "^/app/notebook/.*$", "dest": "/frontend/notebook/index.html" },
    { "src": "^/app/?$", "dest": "/frontend/index.html" },
    { "src": "^/app/.*$", "dest": "/frontend/index.html" },
    { "src": "^/$", "dest": "/frontend/index.html" }
  ]
}


# Backend runtime (Docker specific)
HOST=0.0.0.0
PORT=8000

# Cookies + sessions (seconds)
SESSION_TTL_SECONDS=7200

# Memory optimization for mineru in Docker
# Use CPU-only torch and optimize batch sizes
TORCH_NUM_THREADS=4

# OpenRouter (use free model by default for low-resource environments)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free

# CORS (update with your frontend domain in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Optional: Add your actual OpenRouter API key for custom models
# OPENROUTER_API_KEY=your_key_here

# Optional: Frontend path overrides (usually not needed in Docker)
# FRONTEND_PATH=./frontend
# STATIC_PATH=./frontend/static
# NOTE_PATH=./frontend/notebook
# RESEARCH_PATH=./frontend/research
